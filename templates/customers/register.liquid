<section class="page-width page-template">
  <h1 class="product-title">Registrati</h1>
  {% form 'create_customer' %}
    {{ form.errors | default_errors }}
    <input type="text" name="customer[first_name]" placeholder="Nome">
    <input type="text" name="customer[last_name]" placeholder="Cognome">
    <input type="email" name="customer[email]" placeholder="Email">
    <input type="password" name="customer[password]" placeholder="Password">
    <button class="btn btn-primary" type="submit">Crea account</button>
  {% endform %}
</section>
