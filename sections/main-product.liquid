<section class="as-product-page section-{{ section.id }}">
  <div class="page-width as-product-page__grid">
    <div class="as-product-gallery">
      {% if product.compare_at_price > product.price %}
        <span class="as-product-badge">{{ section.settings.sale_badge }}</span>
      {% elsif product.available %}
        <span class="as-product-badge">{{ section.settings.available_badge }}</span>
      {% else %}
        <span class="as-product-badge">{{ section.settings.soldout_badge }}</span>
      {% endif %}

      <div class="as-product-gallery__main">
        {% if product.featured_image %}
          {{ product.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: product.title }}
        {% else %}
          <div class="as-product-placeholder">
            <div class="as-product-shirt"></div>
          </div>
        {% endif %}
      </div>

      {% if product.images.size > 1 %}
        <div class="as-product-thumbs">
          {% for image in product.images limit: 6 %}
            <div class="as-product-thumb">
              {{ image | image_url: width: 220 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="as-product-panel">
      {% if section.settings.eyebrow != blank %}
        <span class="as-eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      <h1 class="as-product-title">{{ product.title }}</h1>

      {% if section.settings.show_vendor and product.vendor != blank %}
        <div class="as-product-vendor">{{ product.vendor }}</div>
      {% endif %}

      <div class="as-product-price-row">
        <div class="as-product-price">
          <span>{{ product.selected_or_first_available_variant.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <s>{{ product.compare_at_price | money }}</s>
          {% endif %}
        </div>
        {% if section.settings.show_tax_note %}
          <small>{{ section.settings.tax_note }}</small>
        {% endif %}
      </div>

      {% if section.settings.short_text != blank %}
        <div class="as-product-short">{{ section.settings.short_text }}</div>
      {% endif %}

      <div class="as-product-highlights">
        {% for block in section.blocks %}
          {% if block.type == 'highlight' %}
            <div class="as-product-highlight" {{ block.shopify_attributes }}>
              <span>{{ block.settings.icon }}</span>
              <div>
                <b>{{ block.settings.title }}</b>
                <small>{{ block.settings.text }}</small>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% form 'product', product, class: 'as-product-form' %}
        {% if product.variants.size > 1 %}
          <label class="as-product-label" for="ProductSelect-{{ section.id }}">{{ section.settings.variant_label }}</label>
          <select id="ProductSelect-{{ section.id }}" name="id" class="as-product-select">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }}{% unless variant.available %} - {{ section.settings.soldout_badge }}{% endunless %} - {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
        {% else %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {% endif %}

        {% if section.settings.show_custom_fields %}
          <div class="as-custom-box">
            <div class="as-custom-box__head">
              <strong>{{ section.settings.custom_box_title }}</strong>
              <span>{{ section.settings.custom_box_text }}</span>
            </div>

            <label>
              {{ section.settings.team_name_label }}
              <input type="text" name="properties[Nome squadra]" placeholder="{{ section.settings.team_name_placeholder }}">
            </label>

            <div class="as-custom-box__row">
              <label>
                {{ section.settings.player_name_label }}
                <input type="text" name="properties[Nome giocatore]" placeholder="{{ section.settings.player_name_placeholder }}">
              </label>
              <label>
                {{ section.settings.player_number_label }}
                <input type="text" name="properties[Numero]" placeholder="{{ section.settings.player_number_placeholder }}">
              </label>
            </div>

            <label>
              {{ section.settings.notes_label }}
              <textarea name="properties[Note personalizzazione]" rows="3" placeholder="{{ section.settings.notes_placeholder }}"></textarea>
            </label>
          </div>
        {% endif %}

        <div class="as-product-actions">
          <label class="as-product-qty">
            {{ section.settings.quantity_label }}
            <input type="number" name="quantity" value="1" min="1">
          </label>

          <button class="as-btn as-btn--primary as-product-submit" type="submit" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {% if product.selected_or_first_available_variant.available %}
              {{ section.settings.add_to_cart_label }}
            {% else %}
              {{ section.settings.soldout_button_label }}
            {% endif %}
          </button>
        </div>
      {% endform %}

      {% if section.settings.secondary_button_label != blank %}
        <a class="as-btn as-btn--ghost as-product-team-cta" href="{{ section.settings.secondary_button_link }}">
          {{ section.settings.secondary_button_label }}
        </a>
      {% endif %}

      <div class="as-product-service-grid">
        {% if section.settings.shipping_text != blank %}
          <div><b>{{ section.settings.shipping_title }}</b><span>{{ section.settings.shipping_text }}</span></div>
        {% endif %}
        {% if section.settings.return_text != blank %}
          <div><b>{{ section.settings.return_title }}</b><span>{{ section.settings.return_text }}</span></div>
        {% endif %}
      </div>

      <div class="as-product-accordions">
        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
            <details {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
              <summary>{{ block.settings.title }}</summary>
              <div>{{ block.settings.text }}</div>
            </details>
          {% endif %}
        {% endfor %}
        {% if section.settings.show_description %}
          <details>
            <summary>{{ section.settings.description_title }}</summary>
            <div>{{ product.description }}</div>
          </details>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Prodotto premium",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "AntSport Teamwear" },
    { "type": "checkbox", "id": "show_vendor", "label": "Mostra vendor", "default": false },
    { "type": "text", "id": "sale_badge", "label": "Badge sconto", "default": "Promo team" },
    { "type": "text", "id": "available_badge", "label": "Badge disponibile", "default": "Pronto per il team" },
    { "type": "text", "id": "soldout_badge", "label": "Badge esaurito", "default": "Esaurito" },
    { "type": "checkbox", "id": "show_tax_note", "label": "Mostra nota tasse/spedizione", "default": true },
    { "type": "text", "id": "tax_note", "label": "Nota tasse/spedizione", "default": "Tasse incluse. Spedizione calcolata al checkout." },
    { "type": "textarea", "id": "short_text", "label": "Testo breve", "default": "Prodotto pensato per squadre di calcio: personalizzabile con logo società, sponsor, nome e numero." },
    { "type": "text", "id": "variant_label", "label": "Label varianti", "default": "Scegli taglia / variante" },
    { "type": "text", "id": "quantity_label", "label": "Label quantità", "default": "Quantità" },
    { "type": "text", "id": "add_to_cart_label", "label": "Testo aggiungi al carrello", "default": "Aggiungi al carrello" },
    { "type": "text", "id": "soldout_button_label", "label": "Testo bottone esaurito", "default": "Non disponibile" },
    { "type": "checkbox", "id": "show_custom_fields", "label": "Mostra campi personalizzazione", "default": true },
    { "type": "text", "id": "custom_box_title", "label": "Titolo box personalizzazione", "default": "Personalizza il kit" },
    { "type": "text", "id": "custom_box_text", "label": "Testo box personalizzazione", "default": "Aggiungi dettagli per squadra, giocatore e numero. Li useremo per preparare la bozza." },
    { "type": "text", "id": "team_name_label", "label": "Label nome squadra", "default": "Nome squadra" },
    { "type": "text", "id": "team_name_placeholder", "label": "Placeholder nome squadra", "default": "Es. ASD AntSport" },
    { "type": "text", "id": "player_name_label", "label": "Label nome giocatore", "default": "Nome giocatore" },
    { "type": "text", "id": "player_name_placeholder", "label": "Placeholder nome giocatore", "default": "Es. Rossi" },
    { "type": "text", "id": "player_number_label", "label": "Label numero", "default": "Numero" },
    { "type": "text", "id": "player_number_placeholder", "label": "Placeholder numero", "default": "10" },
    { "type": "text", "id": "notes_label", "label": "Label note", "default": "Note per la personalizzazione" },
    { "type": "text", "id": "notes_placeholder", "label": "Placeholder note", "default": "Colori, sponsor, loghi, richieste particolari..." },
    { "type": "text", "id": "secondary_button_label", "label": "Pulsante secondario", "default": "Richiedi preventivo squadra" },
    { "type": "url", "id": "secondary_button_link", "label": "Link pulsante secondario", "default": "/pages/preventivo-team" },
    { "type": "text", "id": "shipping_title", "label": "Titolo spedizione", "default": "Produzione team" },
    { "type": "text", "id": "shipping_text", "label": "Testo spedizione", "default": "Bozza grafica e tempi confermati dopo l’ordine." },
    { "type": "text", "id": "return_title", "label": "Titolo supporto", "default": "Supporto grafico" },
    { "type": "text", "id": "return_text", "label": "Testo supporto", "default": "Ti aiutiamo con logo, sponsor, nomi e numeri." },
    { "type": "checkbox", "id": "show_description", "label": "Mostra descrizione prodotto in accordion", "default": true },
    { "type": "text", "id": "description_title", "label": "Titolo descrizione", "default": "Descrizione prodotto" }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "icon", "label": "Icona", "default": "⚽" },
        { "type": "text", "id": "title", "label": "Titolo", "default": "Team ready" },
        { "type": "text", "id": "text", "label": "Testo", "default": "Perfetto per club e tornei" }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion info",
      "settings": [
        { "type": "text", "id": "title", "label": "Titolo", "default": "Personalizzazione" },
        { "type": "richtext", "id": "text", "label": "Testo", "default": "<p>Puoi indicare nome squadra, giocatore, numero, logo e sponsor nelle note. Ti contatteremo per confermare la bozza grafica.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Prodotto premium",
      "blocks": [
        { "type": "highlight", "settings": { "icon": "⚽", "title": "Team ready", "text": "Pensato per squadre" } },
        { "type": "highlight", "settings": { "icon": "✍️", "title": "Custom", "text": "Nome, numero e logo" } },
        { "type": "highlight", "settings": { "icon": "🚀", "title": "Bozza rapida", "text": "Conferma grafica veloce" } },
        { "type": "accordion", "settings": { "title": "Personalizzazione", "text": "<p>Inserisci i dettagli nei campi dedicati. Per ordini squadra puoi richiedere un preventivo dedicato.</p>" } },
        { "type": "accordion", "settings": { "title": "Taglie e vestibilità", "text": "<p>Consigliamo di indicare nelle note eventuali richieste su taglie miste o kit per tutta la rosa.</p>" } },
        { "type": "accordion", "settings": { "title": "Produzione e consegna", "text": "<p>I tempi vengono confermati dopo la bozza grafica e variano in base alla quantità e al tipo di personalizzazione.</p>" } }
      ]
    }
  ]
}
{% endschema %}
