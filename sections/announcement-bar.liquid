{% if section.settings.text != blank %}
  <div class="announcement">{{ section.settings.text }}</div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "text", "label": "Testo", "default": "Personalizzazioni squadre · Numeri e nomi · Preventivi rapidi" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
