<section class="as-hero as-index-home">
  <div class="page-width as-hero__grid">
    <div class="as-hero__copy">
      <span class="as-eyebrow">Teamwear calcio · Custom kit</span>
      <h1>
        Divise che fanno
        <span>paura in campo.</span>
      </h1>
      <p>
        AntSport crea abbigliamento sportivo personalizzato per squadre di calcio:
        kit gara, training, staff, accessori, nomi, numeri, sponsor e grafiche coordinate.
      </p>

      <div class="as-hero__buttons">
        <a class="as-btn as-btn--primary" href="/pages/preventivo-team">Crea il kit squadra</a>
        <a class="as-btn as-btn--ghost" href="/collections/all">Guarda il catalogo</a>
      </div>

      <div class="as-hero__stats">
        <div>
          <strong>48h</strong>
          <span>bozza grafica</span>
        </div>
        <div>
          <strong>10+</strong>
          <span>kit per team</span>
        </div>
        <div>
          <strong>100%</strong>
          <span>personalizzabile</span>
        </div>
      </div>
    </div>

    <div class="as-hero__visual" aria-label="Maglia AntSport personalizzata">
      <div class="as-field">
        <span class="as-field__line as-field__line--one"></span>
        <span class="as-field__line as-field__line--two"></span>
        <span class="as-field__circle"></span>
      </div>

      <div class="as-jersey">
        <span class="as-jersey__brand">ANTSPORT</span>
        <span class="as-jersey__number">10</span>
        <span class="as-jersey__name">TEAM</span>
      </div>

      <div class="as-floating as-floating--left">
        <b>Nome + Numero</b>
        <small>pronti per tutta la rosa</small>
      </div>

      <div class="as-floating as-floating--right">
        <b>Logo società</b>
        <small>stampa o ricamo</small>
      </div>
    </div>
  </div>
</section>

<section class="as-strip">
  <div class="page-width as-strip__track">
    <span>Kit gara</span>
    <span>Training</span>
    <span>Staff</span>
    <span>Accessori</span>
    <span>Personalizzazioni</span>
    <span>Preventivi rapidi</span>
  </div>
</section>

<section class="as-section">
  <div class="page-width">
    <div class="as-section__head">
      <div>
        <span class="as-eyebrow">Categorie</span>
        <h2>Costruisci il tuo<br>look partita.</h2>
      </div>
      <p>
        Dalla prima squadra alla scuola calcio: scegli una base, aggiungi i colori sociali
        e completa il kit con stampe, sponsor e accessori coordinati.
      </p>
    </div>

    <div class="as-categories">
      <a class="as-category as-category--big" href="/collections/all">
        <span class="as-category__tag">Match day</span>
        <h3>Kit gara</h3>
        <p>Maglia, pantaloncino, calzettone e set portiere.</p>
      </a>
      <a class="as-category" href="/collections/all">
        <span class="as-category__tag">Everyday</span>
        <h3>Training</h3>
        <p>T-shirt, felpe, tute e giacche per allenamento.</p>
      </a>
      <a class="as-category" href="/collections/all">
        <span class="as-category__tag">Club</span>
        <h3>Staff & travel</h3>
        <p>Look coordinato per mister, dirigenti e trasferte.</p>
      </a>
    </div>
  </div>
</section>

<section class="as-section as-section--dark">
  <div class="page-width">
    <div class="as-section__head">
      <div>
        <span class="as-eyebrow">Pacchetti squadra</span>
        <h2>Ordina facile.<br>Gioca forte.</h2>
      </div>
      <p>
        Tre formule pensate per società, tornei e academy. Puoi usarle come base
        per richiedere un preventivo personalizzato.
      </p>
    </div>

    <div class="as-packs">
      <article class="as-pack">
        <div class="as-pack__top">
          <span>Starter</span>
          <strong>10+</strong>
        </div>
        <h3>Per piccoli team</h3>
        <ul>
          <li>Maglia personalizzata</li>
          <li>Nome e numero</li>
          <li>Bozza grafica inclusa</li>
        </ul>
        <a class="as-btn as-btn--ghost" href="/pages/preventivo-team">Richiedi info</a>
      </article>

      <article class="as-pack as-pack--featured">
        <div class="as-pack__top">
          <span>Club</span>
          <strong>20+</strong>
        </div>
        <h3>Per squadre complete</h3>
        <ul>
          <li>Kit gara completo</li>
          <li>Logo società e sponsor</li>
          <li>Gestione taglie rosa</li>
        </ul>
        <a class="as-btn as-btn--primary" href="/pages/preventivo-team">Fai preventivo</a>
      </article>

      <article class="as-pack">
        <div class="as-pack__top">
          <span>Academy</span>
          <strong>50+</strong>
        </div>
        <h3>Per società sportive</h3>
        <ul>
          <li>Linee coordinate per categorie</li>
          <li>Training e staff wear</li>
          <li>Riordini stagionali</li>
        </ul>
        <a class="as-btn as-btn--ghost" href="/pages/preventivo-team">Parla con noi</a>
      </article>
    </div>
  </div>
</section>

<section class="as-section">
  <div class="page-width">
    <div class="as-section__head">
      <div>
        <span class="as-eyebrow">Best seller</span>
        <h2>Prodotti pronti<br>per la rosa.</h2>
      </div>
      <a class="as-btn as-btn--ghost" href="/collections/all">Vai allo shop</a>
    </div>

    {% assign featured_collection = collections['frontpage'] | default: collections['all'] %}
    <div class="as-products">
      {% if featured_collection != blank and featured_collection.products_count > 0 %}
        {% for product in featured_collection.products limit: 4 %}
          {% render 'product-card', product: product %}
        {% endfor %}
      {% else %}
        <article class="as-demo-product">
          <span>Team</span>
          <div class="as-demo-product__shirt"></div>
          <h3>Maglia Gara Pro</h3>
          <p>da €39,90</p>
        </article>
        <article class="as-demo-product">
          <span>Training</span>
          <div class="as-demo-product__shirt as-demo-product__shirt--blue"></div>
          <h3>Kit Allenamento</h3>
          <p>da €29,90</p>
        </article>
        <article class="as-demo-product">
          <span>Staff</span>
          <div class="as-demo-product__shirt as-demo-product__shirt--black"></div>
          <h3>Felpa Staff</h3>
          <p>da €49,90</p>
        </article>
        <article class="as-demo-product">
          <span>Club</span>
          <div class="as-demo-product__bag"></div>
          <h3>Borsa Team</h3>
          <p>da €34,90</p>
        </article>
      {% endif %}
    </div>
  </div>
</section>

<section class="as-lab">
  <div class="page-width as-lab__grid">
    <div>
      <span class="as-eyebrow">AntSport Custom Lab</span>
      <h2>Colori, sponsor,<br>nomi e numeri.</h2>
      <p>
        Parti dai colori della tua società e trasformali in un kit completo.
        Creiamo una proposta grafica chiara prima della produzione.
      </p>

      <div class="as-lab__list">
        <div><b>01</b><span>Invii logo, colori e taglie</span></div>
        <div><b>02</b><span>Ricevi la bozza grafica</span></div>
        <div><b>03</b><span>Confermi e produciamo il teamwear</span></div>
      </div>

      <a class="as-btn as-btn--primary" href="/pages/personalizzazioni">Avvia personalizzazione</a>
    </div>

    <div class="as-lab__board">
      <div class="as-color-card as-color-card--lime">Lime strike</div>
      <div class="as-color-card as-color-card--cyan">Ice blue</div>
      <div class="as-color-card as-color-card--dark">Black pitch</div>
      <div class="as-print-card">
        <span>PLAYER</span>
        <strong>23</strong>
      </div>
    </div>
  </div>
</section>

<section class="as-section">
  <div class="page-width as-process">
    <div>
      <span class="as-eyebrow">Come funziona</span>
      <h2>Dal brief<br>alla partita.</h2>
    </div>

    <div class="as-process__steps">
      <div>
        <strong>1</strong>
        <h3>Scegli base</h3>
        <p>Kit gara, training o pacchetto completo.</p>
      </div>
      <div>
        <strong>2</strong>
        <h3>Personalizza</h3>
        <p>Colori, stemma, sponsor, nomi e numeri.</p>
      </div>
      <div>
        <strong>3</strong>
        <h3>Conferma</h3>
        <p>Ricevi bozza e preventivo finale.</p>
      </div>
      <div>
        <strong>4</strong>
        <h3>Scendi in campo</h3>
        <p>Produzione e consegna del tuo teamwear.</p>
      </div>
    </div>
  </div>
</section>

<section class="as-final-cta">
  <div class="page-width">
    <span class="as-eyebrow">Pronto per il kick-off?</span>
    <h2>Porta la tua squadra<br>a un altro livello.</h2>
    <p>Raccontaci cosa ti serve e ti prepariamo una proposta personalizzata.</p>
    <div class="as-hero__buttons">
      <a class="as-btn as-btn--primary" href="/pages/preventivo-team">Richiedi preventivo team</a>
      <a class="as-btn as-btn--ghost" href="/pages/contact">Contattaci</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Homepage AntSport index",
  "settings": [],
  "presets": [
    {
      "name": "Homepage AntSport index"
    }
  ]
}
{% endschema %}
